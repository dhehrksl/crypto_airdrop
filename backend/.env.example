# ===== 필수 =====
# 백엔드 포트 (기본 3000)
PORT=3000

# MongoDB 연결 URI — 로컬 설치 시 기본값 그대로 사용 가능
MONGODB_URI=mongodb://127.0.0.1:27017/crypto_airdrop

# Gemini API 키 — https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# JWT 서명 키 — 아무 긴 랜덤 문자열로 변경
JWT_SECRET=change-me-to-a-long-random-string

# ===== 서버 부팅에 필수 (Google 로그인 안 써도 더미값 필요) =====
# passport-google-oauth20이 모듈 로드 시 clientID 검증하므로 비워두면 부팅 실패
# Google 로그인 실제 사용 시: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=dummy
GOOGLE_CLIENT_SECRET=dummy

# ===== 선택 =====
# 사용할 Gemini 모델 (기본: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# /api/scraper/run 인증 토큰 — 외부 노출 시 quota 도난 방지용
# 비워두면 인증 비활성화 (로컬 개발용). 운영 환경에서는 반드시 설정.
# 호출 시 헤더: Authorization: Bearer <토큰>  또는  X-Admin-Token: <토큰>
SCRAPER_ADMIN_TOKEN=

# 자동 스크래핑 cron 표현식 (기본: 매시 정각)
# 예) "*/30 * * * *" (30분마다), "0 */2 * * *" (2시간마다)
SCRAPER_CRON=0 * * * *

# 자동 스크래핑 활성화 여부 (false면 HTTP 트리거만 사용)
SCRAPER_CRON_ENABLED=true
