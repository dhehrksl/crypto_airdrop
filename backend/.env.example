# ===== 필수 =====
# 운영(Render 등)에서는 NODE_ENV=production 으로 부팅 자가 진단이 fail-fast 모드 진입.
NODE_ENV=development

# 백엔드 포트 (기본 3000). Render는 PORT를 자동 주입하므로 render.yaml에서 10000 명시.
PORT=3000

# MongoDB 연결 URI
#   로컬: mongodb://127.0.0.1:27017/crypto_airdrop
#   Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/crypto_airdrop?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/crypto_airdrop

# Gemini API 키 — https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# JWT 서명 키 — 운영은 반드시 강한 랜덤값. production 부팅 자가 진단은 약한 기본값/짧은 키를 거절.
#   생성: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string

# /api/scraper/run 인증 토큰 — production 필수. 미설정 시 부팅 거부.
#   생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SCRAPER_ADMIN_TOKEN=

# CORS 화이트리스트 (쉼표 구분). 모바일 native는 origin 헤더 없어 자동 통과.
# production에서 비워두면 부팅 거부. 관리자 웹/Expo Web 빌드가 없으면 임의값(예: https://api.localhost)이라도 채워야 함.
CORS_ALLOWED_ORIGINS=

# ===== 서버 부팅에 필수 (Google 로그인 안 써도 더미값 필요) =====
# passport-google-oauth20이 모듈 로드 시 clientID 검증하므로 비워두면 부팅 실패.
# Google 로그인 실제 사용 시: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=dummy
GOOGLE_CLIENT_SECRET=dummy

# ===== JWT =====
JWT_EXPIRES_IN=1d

# ===== 선택 =====
# 사용할 Gemini 모델
# flash-lite: 1500 RPD/30 RPM (무료) — 큐레이션/분류에 충분
# flash:      20 RPD (무료) — 정확도 우선이지만 무료 quota 부족
GEMINI_MODEL=gemini-2.5-flash-lite

# 자동 스크래핑 cron 표현식 (기본: 매시 정각)
SCRAPER_CRON=0 * * * *
SCRAPER_CRON_ENABLED=true

# Draft 자동 수집기 (기본 6시간마다)
DRAFT_COLLECT_CRON=0 */6 * * *
DRAFT_COLLECT_ENABLED=true

# 만료 에어드랍 강등 (기본 매일 03:00 KST)
AIRDROP_RETENTION_CRON=0 3 * * *
AIRDROP_RETENTION_ENABLED=true

# Draft 수집기 — Telegram 공개 채널 (쉼표 구분, t.me/s/<name>로 미리보기 활성 채널만)
TELEGRAM_CHANNELS=airdropalert,airdrops_official,AirdropDetective

# Draft 수집기 — Reddit (기본 false; ToS 회색 영역)
DRAFT_REDDIT_ENABLED=false
REDDIT_SUBREDDITS=airdrops,CryptoAirdrops
